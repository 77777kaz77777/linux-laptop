#!/bin/bash

# Exit immediately if a command exits with a non-zero status
set -e

# Log file
LOGFILE="update_log.txt"

# Function to log messages
log_message() {
    echo "$1" | tee -a "$LOGFILE"
}

# Update package index
log_message "Updating package index..."
sudo apt update -q | tee -a "$LOGFILE"

# Upgrade installed packages
log_message "Upgrading installed packages..."
sudo apt full-upgrade -y -q | tee -a "$LOGFILE"

# Remove unnecessary packages
log_message "Removing unnecessary packages..."
sudo apt autoremove -y -q | tee -a "$LOGFILE"

# Clean up local repository
log_message "Cleaning up local repository..."
sudo apt autoclean -q | tee -a "$LOGFILE"

# Note: autopurge is not a standard command; consider using purge for specific packages if needed
# Uncomment the following line if you have specific packages to purge
# log_message "Purging specific packages..."
# sudo apt purge <package_name> | tee -a "$LOGFILE"

# Update Flatpak applications
log_message "Updating Flatpak applications..."
sudo flatpak update -y | tee -a "$LOGFILE"

# Completion message
log_message "All updates and cleanups completed successfully at $(date)!"
