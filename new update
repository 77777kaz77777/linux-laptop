#!/bin/bash

# Exit immediately if a command exits with a non-zero status
set -e

# Log file
LOGFILE="/var/log/packageupdateslogs/update_log.txt"

# Create the log directory if it doesn't exist
if [ ! -d "/var/log/packageupdateslogs" ]; then
    mkdir -p /var/log/packageupdateslogs
fi

# Function to log messages
log_message() {
    echo "$1" | tee -a "$LOGFILE"
}

# Update package index
log_message "Updating package index..."
apt-get update -q 2>> "$LOGFILE"

# Upgrade installed packages
log_message "Upgrading installed packages..."
apt-get full-upgrade -y -q 2>> "$LOGFILE"

# Remove unnecessary packages
log_message "Removing unnecessary packages..."
apt-get autoremove -y -q 2>> "$LOGFILE"

# Clean up local repository
log_message "Cleaning up local repository..."
apt-get autoclean -q 2>> "$LOGFILE"

# Update Flatpak applications
log_message "Updating Flatpak applications..."
flatpak update -y 2>> "$LOGFILE"

# Completion message
log_message "All updates and cleanups completed successfully at $(date)! Log file: $LOGFILE"
