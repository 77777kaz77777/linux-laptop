#!/bin/bash

# Exit immediately if a command exits with a non-zero status
set -e

# Require script to be run as root to avoid peppering 'sudo' everywhere
if [[ $EUID -ne 0 ]]; then
   echo "Error: This script must be run as root. Please run with sudo." 
   exit 1
fi

# Log file configuration
LOG_DIR="/var/log/packageupdateslogs"
LOGFILE="$LOG_DIR/update_log.txt"

# Create the log directory if it doesn't exist
if [ ! -d "$LOG_DIR" ]; then
    mkdir -p "$LOG_DIR"
fi

# Function to log messages with timestamps to both console and file
log_message() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOGFILE"
}

# Start log
log_message "--- Starting System Maintenance ---"

# 1. Update package index and upgrade system (Standard repos)
log_message "Updating package index and upgrading system via pacman..."
pacman -Syu --noconfirm >> "$LOGFILE" 2>&1

# 2. Remove unnecessary packages (orphans)
log_message "Checking for unnecessary (orphan) packages..."
# '|| true' prevents set -e from killing the script if no orphans are found
ORPHANS=$(pacman -Qtdq || true)

if [ -n "$ORPHANS" ]; then
    log_message "Removing orphan packages..."
    # Word splitting is intentional here so pacman reads multiple packages
    pacman -Rns $ORPHANS --noconfirm >> "$LOGFILE" 2>&1
else
    log_message "No orphan packages to remove."
fi

# 3. Clean up local repository cache
log_message "Cleaning up local package cache..."
# Use paccache if installed (part of pacman-contrib), keeps 3 most recent versions
if command -v paccache &> /dev/null; then
    paccache -r >> "$LOGFILE" 2>&1
else
    log_message "paccache not found (pacman-contrib not installed). Skipping..."
fi

# Removes uninstalled packages from cache
pacman -Sc --noconfirm >> "$LOGFILE" 2>&1

# 4. Update Flatpak applications
if command -v flatpak &> /dev/null; then
    log_message "Updating Flatpak applications..."
    flatpak update -y >> "$LOGFILE" 2>&1
    
    # Remove unused flatpak runtimes (similar to pacman orphans)
    log_message "Cleaning up unused Flatpak runtimes..."
    flatpak uninstall --unused -y >> "$LOGFILE" 2>&1
else
    log_message "Flatpak is not installed. Skipping..."
fi

# Completion message
log_message "All updates and cleanups completed successfully!"
log_message "Log file available at: $LOGFILE"
echo "" >> "$LOGFILE" # Add a blank line in the log for readability between runs
