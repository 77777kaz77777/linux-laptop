#!/bin/bash

# Ensure the script is run as root
if [ "$EUID" -ne 0 ]; then 
  echo "Please run as root (use sudo)"
  exit 1
fi

# Configuration
LOG_DIR="/var/log/packageupdateslogs"
LOGFILE="$LOG_DIR/update_log.txt"
USER_NAME=$(logname) # Get the actual user to send desktop notifications

# Initialize environment
mkdir -p "$LOG_DIR"
set -e

# Function to log and notify
log_info() {
    local msg="$1"
    echo "[( $(date +'%Y-%m-%d %H:%M:%S') )] $msg" | tee -a "$LOGFILE"
}

# Function to send desktop notifications (Requires libnotify-bin)
notify() {
    sudo -u "$USER_NAME" DISPLAY=:0 DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/$(id -u "$USER_NAME")/bus notify-send "System Update" "$1"
}

# 1. Handle APT Locks
# Sometimes the GUI 'Software Updater' holds the lock. This waits for it to finish.
log_info "Checking for package manager locks..."
while fuser /var/lib/dpkg/lock-frontend >/dev/null 2>&1; do
    log_info "Waiting for other package managers to finish..."
    sleep 5
done

# 2. Update APT Packages
log_info "Updating APT package index..."
apt-get update -q -y

log_info "Upgrading APT packages..."
# 'dist-upgrade' or 'full-upgrade' is better for desktop to handle dependency changes
apt-get full-upgrade -y

# 3. Update Snaps (Crucial for Ubuntu Desktop)
if command -v snap &> /dev/null; then
    log_info "Updating Snap packages..."
    snap refresh 2>> "$LOGFILE"
fi

# 4. Update Flatpaks
if command -v flatpak &> /dev/null; then
    log_info "Updating Flatpaks..."
    flatpak update -y 2>> "$LOGFILE"
fi

# 5. Cleanup
log_info "Cleaning up old packages and cache..."
apt-get autoremove -y
apt-get autoclean

# 6. Check if a reboot is required
if [ -f /var/run/reboot-required ]; then
    log_info "REBOOT REQUIRED"
    notify "Update complete. A reboot is required to apply changes."
else
    log_info "Update complete. No reboot necessary."
    notify "System is up to date."
fi

log_info "All updates completed successfully."
